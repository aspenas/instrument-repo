{
  "name": "instrument-architecture",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "qa:browsers": "playwright install chromium",
    "qa:live": "node ./scripts/visual-audit.mjs --base-url=https://instruments.highline.work --output-dir=artifacts/visual-audit/live",
    "qa:local": "node ./scripts/run-visual-audit.mjs",
    "qa:build": "npm run build && npm run qa:local"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/permanent-marker": "^5.2.7",
    "clsx": "^2.1.1",
    "lenis": "^1.3.21",
    "lucide-react": "^0.554.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.16",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.1.16",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5",
    "wrangler": "^4.45.3"
  }
}
